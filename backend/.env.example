# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="FinsightAI Backend"
ENVIRONMENT=development
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── MCP Server ────────────────────────────────────────────────────────────────
# URL of the running FastMCP HTTP server (see ../MCP)
MCP_SERVER_URL=http://localhost:8080/mcp

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Format: "provider:model-name"
# Examples: openai:gpt-4.1  |  anthropic:claude-opus-4-5  |  ollama:llama3
LLM_MODEL=openai:gpt-4.1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# API keys – only the key matching your chosen provider is required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_RECURSION_LIMIT=25
