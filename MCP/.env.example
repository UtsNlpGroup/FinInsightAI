# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Leave CHROMA_HOST empty to use a local persistent client (default).
# Set to a hostname/IP to connect to a running ChromaDB HTTP server instead.
CHROMA_HOST=
CHROMA_PORT=8000

# Directory for local persistent ChromaDB storage (used when CHROMA_HOST is empty)
CHROMA_PERSIST_DIR=./chroma_data

# Default collection name for financial documents
CHROMA_DEFAULT_COLLECTION=financial_docs

# ── Embeddings ────────────────────────────────────────────────────────────────
# Set your OpenAI API key to use text-embedding-3-small for richer embeddings.
# Leave empty to fall back to the built-in all-MiniLM-L6-v2 model (no API key needed).
OPENAI_API_KEY=

# ── MCP Transport ─────────────────────────────────────────────────────────────
# Transport mode: "stdio" (default, for local MCP clients) or "http" (remote access)
MCP_TRANSPORT=stdio
MCP_PORT=8080
